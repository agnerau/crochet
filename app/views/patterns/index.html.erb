<div class="pattern-wrapper">
  <div class="pattern-card">
    <h1>🎀 Crochet Pattern Generator 🎀</h1>

    <%= form_with url: "/generate", method: :post, local: true do |f| %>
      <div class="form-group">
        <label>Pattern name</label>
        <%= text_field_tag :pattern_name, "Flower", class: "input-field", placeholder: "Flower" %>
      </div>

      <div class="form-group">
        <label>Width (squares) </label>
        <%= number_field_tag :width, 10, class: "input-field", placeholder: "10", min: GRID_MIN, max: GRID_MAX, step: 1 %>
      </div>

      <div class="form-group">
        <label>Height (squares) </label>
        <%= number_field_tag :height, 10, class: "input-field", placeholder: "10", min: GRID_MIN, max: GRID_MAX, step: 1 %>
      </div>

      <%= submit_tag "Generate :3", class: "generate-btn" %>
    <% end %>
  </div>
</div>