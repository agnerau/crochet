<h2 class="title">🎀 Pattern 🎀</h2>

<div class="grid">
  <% @grid.each do |row| %>
    <% row.each do |cell| %>
      <% if cell == 1 %>
        <div class="filled"></div>
      <% else %>
        <div class="empty"></div>
      <% end %>
    <% end %>
  <% end %>
</div>

<br>
<%= link_to "Back", root_path, class: "back-button" %>

<style>
  /* Center everything */
  body, html {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    # font-family: 'Comic Sans MS', cursive, sans-serif;
    background: #ffeef8;
    min-height: 100vh;
    margin: 0;
  }

  .title {
    color: #ff69b4;
    font-size: 2.5rem;
    margin-bottom: 20px;
    text-shadow: 1px 1px #fff;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(<%= @grid.first.size %>, 25px);
    gap: 4px;
    background: #fff0f5;
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 4px 10px rgba(255, 105, 180, 0.3);
  }

  .grid div {
    width: 25px;
    height: 25px;
    border-radius: 5px;
  }

  .filled {
    background-color: #ff69b4;
  }

  .empty {
    background-color: #ffeef8;
    border: 1px solid #ffb6c1;
  }

  .back-button {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 20px;
    background-color: #ff69b4;
    color: white;
    font-weight: bold;
    text-decoration: none;
    border-radius: 10px;
    transition: 0.3s;
  }

  .back-button:hover {
    background-color: #ff85c1;
  }
</style>